# Copy this file to ".env" (same folder) and fill in your key.

# Required: your OpenAI API key.
OPENAI_API_KEY=sk-replace-me

# Any model you have access to. gpt-4o is a solid default for an agent.
OPENAI_MODEL=gpt-4o

# Leave as-is unless you're routing through an OpenAI-compatible proxy.
OPENAI_BASE_URL=https://api.openai.com/v1

# false = Athena asks before running commands or writing files (recommended).
# true  = Athena acts without asking. Only on machines you fully trust.
AUTO_APPROVE=false

# What it calls itself.
AGENT_NAME=Athena
