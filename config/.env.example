# Copy this file to ".env" (same folder) and fill in your keys.

# -- OpenAI -------------------------------------------------------------------
# Required for: GPT models, embeddings (semantic memory), summarization
OPENAI_API_KEY=sk-replace-me

# Active model. Switch anytime with /model <name> or the UI dropdown.
# Options: gpt-4o, gpt-4o-mini, gpt-5.5, gpt-5.4-mini
OPENAI_MODEL=gpt-4o

# Leave as-is unless routing through an OpenAI-compatible proxy.
OPENAI_BASE_URL=https://api.openai.com/v1

# -- Anthropic (Claude) -------------------------------------------------------
# Required for: Claude models (claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001)
# Leave blank if you only use OpenAI/NVIDIA.
ANTHROPIC_API_KEY=

# -- NVIDIA NIM ---------------------------------------------------------------
# Required for: NVIDIA-hosted models (Nemotron, DeepSeek, Llama, etc.)
# Get a key at: https://build.nvidia.com
NVIDIA_API_KEY=

# -- Voyage AI ----------------------------------------------------------------
# Required for: semantic memory / recall (best for code + technical content)
# Recommended over OpenAI embeddings for Athena's use case.
# Get a key at: https://dash.voyageai.com
# Priority order for embeddings: Voyage AI → NVIDIA NIM → OpenAI
VOYAGE_API_KEY=

# -- Brave Search -------------------------------------------------------------
# Required for: web_search tool
# Get a key at: https://brave.com/search/api/
BRAVE_API_KEY=

# -- Behaviour ----------------------------------------------------------------
# false = Athena asks before running shell commands or writing files (recommended)
# true  = Athena acts without asking. Only on machines you fully trust.
AUTO_APPROVE=false

# What she calls herself.
AGENT_NAME=Athena

# -- Offline mode (no API key required) ---------------------------------------
# Run runtime/get-offline.sh (Linux/macOS) or runtime/get-offline.ps1 (Windows)
# to download the llama-server binary and Phi-3.5-mini model (~2.2 GB).
# After that, Athena runs fully offline with no API key needed.
#
# Optional: override the default port (17860) if another process uses it.
# LOCAL_LLM_PORT=17860
